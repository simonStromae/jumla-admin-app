generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  client
  agent
  admin
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String
  name               String
  phone              String?
  role               UserRole  @default(client)
  status             String    @default("active")
  emailVerified      Boolean   @default(false)
  verifyToken        String?
  mustChangePassword Boolean   @default(false)
  permissions        Json      @default("{}")
  city               String?
  country            String    @default("CM")
  addresses          Json?
  createdAt          DateTime  @default(now())

  parcels          Parcel[]
  payments         Payment[]
  sentMessages     Message[]       @relation("sender")
  receivedMessages Message[]       @relation("recipient")
  trackingEvents   TrackingEvent[]
  campaignCosts    CampaignCost[]
  campaigns        Campaign[]

  @@map("users")
}

model Route {
  id          String     @id @default(cuid())
  origin      String
  destination String
  label       String?
  active      Boolean    @default(true)
  campaigns   Campaign[]

  @@map("routes")
}

model Campaign {
  id            String         @id @default(cuid())
  code          String         @unique
  routeId       String
  route         Route          @relation(fields: [routeId], references: [id])
  departureDate DateTime?
  arrivalDate   DateTime?
  status        String         @default("enr")
  capacityKg    Float?
  createdById   String?
  createdBy     User?          @relation(fields: [createdById], references: [id])
  createdAt     DateTime       @default(now())

  costs         CampaignCost?
  parcels       Parcel[]

  @@map("campaigns")
}

model CampaignCost {
  campaignId  String   @id
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fret        Int      @default(0)
  manutention Int      @default(0)
  douane      Int      @default(0)
  entrepot    Int      @default(0)
  transport   Int      @default(0)
  divers      Int      @default(0)
  enteredById String?
  enteredBy   User?    @relation(fields: [enteredById], references: [id])
  updatedAt   DateTime @updatedAt

  @@map("campaign_costs")
}

model Parcel {
  id            String       @id @default(cuid())
  clientId      String
  client        User         @relation(fields: [clientId], references: [id])
  campaignId    String
  campaign      Campaign     @relation(fields: [campaignId], references: [id])
  trackingCode  String       @unique
  description   String?
  weightKg      Float?
  declaredValue Float?
  priceXaf      Int?
  // Tarification
  productType       String?  @default("standard")
  nbCartons         Int?     @default(0)
  nbPetitsSacs      Int?     @default(0)
  nbSacsMoyens      Int?     @default(0)
  nbGrandsSacs      Int?     @default(0)
  nbPlastiques      Int?     @default(0)
  nbPlastiquesBiere Int?     @default(0)
  nbCasiers24x65    Int?     @default(0)
  nbCasiers24x33    Int?     @default(0)
  nbCasiers12x50    Int?     @default(0)
  marginPct         Float?   @default(30)
  pricingDetails    Json?
  items             Json?
  bordereaux        Bordereau[]
  status        String       @default("enr")
  confirmed     Boolean      @default(false)
  notes         String?
  createdAt     DateTime     @default(now())

  payment        Payment?
  trackingEvents TrackingEvent[]

  @@map("parcels")
}

model Payment {
  id         String        @id @default(cuid())
  parcelId   String        @unique
  parcel     Parcel        @relation(fields: [parcelId], references: [id])
  clientId   String
  client     User          @relation(fields: [clientId], references: [id])
  amount     Int
  status     String        @default("pending")
  interacRef String?
  paidAt     DateTime?
  createdAt  DateTime      @default(now())

  @@map("payments")
}

model TrackingEvent {
  id          String       @id @default(cuid())
  parcelId    String
  parcel      Parcel       @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  status      String
  location    String?
  note        String?
  createdById String?
  createdBy   User?        @relation(fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())

  @@map("tracking_events")
}

model Message {
  id          String    @id @default(cuid())
  senderId    String
  sender      User      @relation("sender", fields: [senderId], references: [id])
  recipientId String
  recipient   User      @relation("recipient", fields: [recipientId], references: [id])
  campaignId  String?
  body        String
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@map("messages")
}

model Bordereau {
  id                String    @id @default(cuid())
  parcelId          String
  parcel            Parcel    @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  code              String
  description       String?
  weightKg          Float?
  nbPieces          Int       @default(1)
  items             Json?
  status            String    @default("en_attente")
  notes             String?
  clientConfirmed   Boolean   @default(false)
  clientConfirmedAt DateTime?
  createdAt         DateTime  @default(now())

  @@map("bordereaux")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model WhatsappLog {
  id        String   @id @default(cuid())
  parcelId  String?
  toPhone   String
  body      String
  status    String   @default("pending")
  twilioSid String?
  error     String?
  sentAt    DateTime @default(now())

  @@map("whatsapp_logs")
}
